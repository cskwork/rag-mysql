# --- Database Configuration ---
# The connection details for your MySQL database.
DB_HOST=your-mysql-host
DB_PORT=3306
DB_USER=your-mysql-user
DB_PASSWORD=your-mysql-password
DB_NAME=your-mysql-database

# --- Ollama Configuration ---
# Specifies the model to be used by Ollama.
# You can see available models by running `ollama list` in your terminal.
# See more models at https://ollama.com/library
OLLAMA_MODEL="gemma3n:latest"

# --- Vanna.ai Configuration ---
# If you have a Vanna.ai account, you can use it to store your training data remotely.
# This is optional. If you leave these blank, it will use a local ChromaDB instance.
# You can get a free API key from https://vanna.ai
VANNA_API_KEY=""
# You can create a model name at https://vanna.ai/models
VANNA_MODEL="my-model"

# --- Application Configuration ---
# The host and port on which the Flask web application will run.
FLASK_HOST=0.0.0.0
FLASK_PORT=8084

# --- Gunicorn Configuration ---
# The number of worker processes for Gunicorn.
# A common recommendation is (2 * number_of_cpu_cores) + 1
GUNICORN_WORKERS=4 